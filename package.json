{
  "name": "rustdyno",
  "version": "0.0.4",
  "main": "./dist/extension.js",
  "icon": "imgs/dyno.png",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/iarna__toml": "^2.0.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "activationEvents": [],
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "rustdyno.selectBoard",
        "title": "rustdyno: Select Board"
      },
      {
        "command": "rustdyno.build",
        "title": "rustdyno: Build"
      },
      {
        "command": "rustdyno.flash",
        "title": "rustdyno: Flash"
      },
      {
        "command": "rustdyno.rtt",
        "title": "rustdyno: RTT Monitor"
      },
      {
        "command": "rustdyno.newProject",
        "title": "rustdyno: New Project"
      }
    ],
    "configuration": {
      "title": "rustdyno",
      "properties": {
        "rustdyno.boardConfigDir": {
          "type": "string",
          "default": ".rustdyno",
          "description": "Directory containing board TOML configs"
        },
        "rustdyno.probersPath": {
          "type": "string",
          "default": "probe-rs",
          "description": "Path to probe-rs binary"
        },
        "rustdyno.pickerGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["src/**/*.rs"],
          "description": "Glob patterns (relative to workspace root) for the file picker"
        },
        "rustdyno.boardLibraryRepo": {
          "type": "string",
          "default": "tmpk13/rustdyno",
          "description": "GitHub repo (owner/repo) to use as the board library, e.g. \"my-org/rustdyno-boards\""
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rustdyno",
          "title": "rustdyno",
          "icon": "imgs/dyno.svg"
        }
      ]
    },
    "views": {
      "rustdyno": [
        {
          "type": "webview",
          "id": "rustdyno.panel",
          "name": "rustdyno"
        }
      ]
    }
  },
  "publisher": "Tmpk-rs",
  "description": "Rust embedded runner",
  "displayName": "rustdyno",
  "engines": {
    "vscode": "^1.110.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "bun test src/test/newProject.test.ts src/test/flasher.test.ts src/test/checker.test.ts"
  },
  "dependencies": {
    "@iarna/toml": "^3.0.0"
  },
  "readme": "README.vscode.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmpk13/rustdyno"
  }
}
