{
  "name": "rdyno",
  "version": "0.0.1",
  "main": "./dist/extension.js",
  "devDependencies": {
    "@types/iarna__toml": "^2.0.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "activationEvents": [],
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "rdyno.selectBoard",
        "title": "rdyno: Select Board"
      },
      {
        "command": "rdyno.build",
        "title": "rdyno: Build"
      },
      {
        "command": "rdyno.flash",
        "title": "rdyno: Flash"
      },
      {
        "command": "rdyno.rtt",
        "title": "rdyno: RTT Monitor"
      },
      {
        "command": "rdyno.newProject",
        "title": "rdyno: New Project"
      }
    ],
    "configuration": {
      "title": "rdyno",
      "properties": {
        "rdyno.boardConfigDir": {
          "type": "string",
          "default": ".rdyno",
          "description": "Directory containing board TOML configs"
        },
        "rdyno.probersPath": {
          "type": "string",
          "default": "probe-rs",
          "description": "Path to probe-rs binary"
        },
        "rdyno.pickerGlobs": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["src/**/*.rs"],
          "description": "Glob patterns (relative to workspace root) for the file picker"
        },
        "rdyno.boardLibraryRepo": {
          "type": "string",
          "default": "tmpk13/rdyno",
          "description": "GitHub repo (owner/repo) to use as the board library, e.g. \"my-org/rdyno-boards\""
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rdyno",
          "title": "rdyno",
          "icon": "./imgs/dyno.svg"
        }
      ]
    },
    "views": {
      "rdyno": [
        {
          "type": "webview",
          "id": "rdyno.panel",
          "name": "Board Controls"
        },
        {
          "type": "webview",
          "id": "rdyno.newProject",
          "name": "New Project"
        },
        {
          "type": "webview",
          "id": "rdyno.boardLibrary",
          "name": "Board Library"
        }
      ]
    }
  },
  "description": "Rust embedded runner",
  "displayName": "rdyno",
  "engines": {
    "vscode": "^1.110.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@iarna/toml": "^3.0.0"
  }
}
